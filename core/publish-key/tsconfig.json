{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "preserveConstEnums": true,
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./build/",
        "noImplicitAny": true
    },
    "exclude": ["node_modules", "build", "coverage"],
    "include": ["./src", "./tests"]
}
